# ============================================================
# ImmoGo — Configuration API
# ============================================================
# IMPORTANT : Décommentez UNE SEULE ligne selon votre contexte
# Après chaque changement, relancez le build de l'application
# ============================================================

# Émulateur Android (Android Studio) — WAMP sur la machine hôte
# 10.0.2.2 = passerelle vers localhost depuis l'émulateur Android
#API_BASE_URL=http://10.0.2.2/ImmoGo/memoire-immo/ImmoGoB-nin/public/api

# Appareil physique — remplacez l'IP par votre IP réseau locale (vérifiez avec ipconfig)
# Le backend doit être accessible sur cette IP (WAMP port 80 ou artisan serve)
API_BASE_URL=http://192.168.181.233/ImmoGo/memoire-immo/ImmoGoB-nin/public/api

# Émulateur iOS
# API_BASE_URL=http://127.0.0.1/ImmoGo/memoire-immo/ImmoGoB-nin/public/api

# Production
# API_BASE_URL=https://immogo.ton-domaine.com/api

